<base:WpfUiWindow x:Class="Shadowstrap.UI.Elements.Dialogs.SunsetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:base="clr-namespace:Shadowstrap.UI.Elements.Base"
        mc:Ignorable="d"
        Title="NIX — Project Discontinued"
        MinWidth="0"
        MinHeight="0"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Padding="8" Title="NIX — Project Discontinued"
                     ShowMinimize="False" ShowMaximize="False" CanMaximize="False"
                     KeyboardNavigation.TabNavigation="None"
                     Icon="pack://application:,,,/Shadowstrap.ico" />

        <StackPanel Grid.Row="1" Margin="20,16,20,20">

            <!-- Red accent bar -->
            <Border Height="2" CornerRadius="1" Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#EF4444" Offset="0" />
                        <GradientStop Color="#DC2626" Offset="0.55" />
                        <GradientStop Color="Transparent" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Header row: icon + title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBlock Text="🌙" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="19" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Text="NIX is shutting down." />
                    <TextBlock FontSize="11" Foreground="#EF4444" FontFamily="Consolas"
                               Text="PROJECT DISCONTINUED  ·  v2.0.9 FINAL" Margin="0,3,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Body -->
            <TextBlock FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,10">
                Shadowstrap was a proof of concept — a test of what a Roblox
                bootstrapper could actually be. That question has been answered.
                The project is now discontinued and will receive no further updates.
            </TextBlock>

            <TextBlock FontSize="14" TextWrapping="Wrap" LineHeight="22"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                Click <Bold>Uninstall Now</Bold> to remove NIX and restore
                the default Roblox launcher. Your Roblox installation and
                saved games are completely untouched.
            </TextBlock>

        </StackPanel>

        <!-- Button bar -->
        <Border Grid.Row="2" Padding="15,12" Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="UninstallButton"
                        MinWidth="130"
                        Content="Uninstall Now"
                        Click="UninstallButton_Click" />
                <Button x:Name="DismissButton"
                        MinWidth="100"
                        Margin="12,0,0,0"
                        Content="Not Now"
                        IsCancel="True" />
            </StackPanel>
        </Border>

    </Grid>
</base:WpfUiWindow>
