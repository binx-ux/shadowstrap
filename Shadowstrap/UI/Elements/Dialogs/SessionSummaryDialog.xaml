<base:WpfUiWindow x:Class="Shadowstrap.UI.Elements.Dialogs.SessionSummaryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:base="clr-namespace:Shadowstrap.UI.Elements.Base"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Session Summary"
        Width="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{ui:ThemeResource ApplicationBackgroundBrush}"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen"
        Topmost="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Padding="8" Title="Session Summary"
                     ShowMinimize="False" ShowMaximize="False" CanMaximize="False"
                     KeyboardNavigation.TabNavigation="None"
                     Icon="pack://application:,,,/Shadowstrap.ico" />

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="20,12,20,16">

            <!-- Game card -->
            <Border CornerRadius="6"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    Padding="14,12" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Border Width="52" Height="52" CornerRadius="4" Margin="0,0,14,0">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding ThumbnailUrl, IsAsync=True}"
                                        Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding GameName}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CreatorName}" FontSize="12" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stats grid -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Time played"
                           Margin="0,0,20,10" VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Duration}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Joined"
                           Margin="0,0,20,10" VerticalAlignment="Center" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TimeJoined}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Left"
                           Margin="0,0,20,10" VerticalAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TimeLeft}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Server region"
                           Margin="0,0,20,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRegion}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Region}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasRegion}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- Buttons -->
        <Border Grid.Row="2" Padding="14,10"
                Background="{ui:ThemeResource SolidBackgroundFillColorSecondaryBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Rejoin" Icon="Play28" IconFilled="True"
                           Appearance="Success" Foreground="White" IconForeground="White"
                           Margin="0,0,10,0"
                           Command="{Binding RejoinCommand}">
                    <ui:Button.Style>
                        <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanRejoin}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <Button MinWidth="80" Content="Close" IsCancel="True" Click="CloseButton_Click" />
            </StackPanel>
        </Border>
    </Grid>
</base:WpfUiWindow>
