<ui:UiPage x:Class="Shadowstrap.UI.Elements.Settings.Pages.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800"
      Title="InventoryPage"
      Scrollable="True">

    <StackPanel Margin="0,0,14,14">

        <!-- Description -->
        <TextBlock Margin="0,0,0,16" FontSize="14"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   Text="Look up any public Roblox player's collectible inventory. Shows Limited and Limited U items with their Recent Average Price (RAP)." />

        <!-- Search row -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox x:Name="UsernameTextBox" Grid.Column="0"
                        PlaceholderText="Roblox username or user ID"
                        KeyDown="UsernameTextBox_KeyDown" />
            <ui:Button x:Name="SearchButton" Grid.Column="2"
                       Icon="Search32" Content="Look up"
                       Appearance="Primary"
                       Click="SearchButton_Click" />
        </Grid>

        <!-- Loading state -->
        <StackPanel x:Name="LoadingPanel" Visibility="Collapsed"
                    HorizontalAlignment="Center" Margin="0,32,0,32">
            <ui:ProgressRing IsIndeterminate="True" Width="44" Height="44"
                             HorizontalAlignment="Center" />
            <TextBlock Text="Loading inventory…" Margin="0,14,0,0"
                       HorizontalAlignment="Center" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Error panel -->
        <Border x:Name="ErrorPanel" Visibility="Collapsed"
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                BorderThickness="1" BorderBrush="#7F1D1D">
            <Border.Background>
                <SolidColorBrush Color="#DC2626" Opacity="0.12" />
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠  " FontSize="14" Foreground="#EF4444" VerticalAlignment="Center" />
                <TextBlock x:Name="ErrorText" FontSize="13" Foreground="#EF4444"
                           TextWrapping="Wrap" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Summary card -->
        <Border x:Name="SummaryBorder" Visibility="Collapsed"
                CornerRadius="10" Padding="20,16" Margin="0,0,0,16"
                BorderThickness="1" BorderBrush="#3D2D6B">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1a0a2e" Offset="0" />
                    <GradientStop Color="#2d1b4e" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: username + count -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="SummaryUsernameText"
                               FontSize="18" FontWeight="SemiBold" Foreground="#A78BFA" />
                    <TextBlock x:Name="SummaryItemsText"
                               FontSize="12" Foreground="#8B7AB8" Margin="0,3,0,0" />
                </StackPanel>

                <!-- Right: total RAP -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="Total RAP" FontSize="11" Foreground="#8B7AB8"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="SummaryRAPText"
                               FontSize="22" FontWeight="Bold" Foreground="#22C55E"
                               HorizontalAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items grid (WrapPanel via ItemsControl) -->
        <ItemsControl x:Name="ItemsControl" Visibility="Collapsed">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="148" Margin="4" CornerRadius="8" Padding="10"
                            BorderThickness="1" Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"   Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                <Setter Property="BorderBrush"  Value="{DynamicResource ControlElevationBorderBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#8B5CF6" />
                                        <Setter Property="Background"  Value="#130828" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <!-- Thumbnail -->
                            <Border Width="100" Height="100" CornerRadius="6"
                                    HorizontalAlignment="Center" Margin="0,0,0,8"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}">
                                <Image Width="100" Height="100" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                                    <Image.Source>
                                        <Binding Path="ThumbnailUrl" />
                                    </Image.Source>
                                </Image>
                            </Border>

                            <!-- Name -->
                            <TextBlock Text="{Binding Name}"
                                       FontSize="10.5" TextWrapping="Wrap"
                                       MaxHeight="34" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Margin="0,0,0,5" />

                            <!-- RAP -->
                            <TextBlock Text="{Binding RAPDisplay}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="#22C55E"
                                       HorizontalAlignment="Center" />

                            <!-- Serial (shown only if set) -->
                            <TextBlock Text="{Binding SerialDisplay}"
                                       FontSize="10" Foreground="#8B7AB8"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding HasSerial, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Load more -->
        <ui:Button x:Name="LoadMoreButton" Content="Load more items"
                   Visibility="Collapsed" HorizontalAlignment="Center"
                   Appearance="Secondary" Margin="0,16,0,0"
                   Click="LoadMoreButton_Click" />

    </StackPanel>
</ui:UiPage>
