<ui:UiPage x:Class="Shadowstrap.UI.Elements.Settings.Pages.GameProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:Shadowstrap.UI.Elements.Controls"
      mc:Ignorable="d"
      d:DesignHeight="900" d:DesignWidth="800"
      Title="GameProfilesPage"
      Scrollable="True"
      Loaded="Page_Loaded">

    <StackPanel Margin="0,0,14,14">

        <!-- Description + global toggle -->
        <TextBlock Margin="0,0,0,12" FontSize="14" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Text="Automatically write a custom FastFlag set when you join a specific game. Flags are saved to disk on join — use the session summary Rejoin button or Auto-Rejoin so they take effect immediately." />

        <ui:CardControl Margin="0,8,0,0">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock FontSize="14" Text="Enable Game Profiles" />
                    <TextBlock FontSize="12" Margin="0,2,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               Text="Auto-apply flag sets on game join." />
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="GlobalToggle" IsChecked="True"
                             Click="GlobalToggle_Click" />
        </ui:CardControl>

        <!-- ── Built-in profiles ──────────────────────────────────────── -->
        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,24,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
            <Run Text="🎮 Built-in Profiles" />
        </TextBlock>
        <Border Height="2" Margin="0,6,0,12" CornerRadius="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#8B5CF6" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   Margin="0,0,0,10" TextWrapping="Wrap"
                   Text="Shipped with NIX. Toggle each game on or off. Place IDs are listed below the name — if a game update changes the place, edit or create a custom profile." />

        <ItemsControl x:Name="BuiltInList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Padding="12,10" Margin="0,3" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Image Width="44" Height="44" Stretch="UniformToFill"
                                       Source="{Binding ThumbnailUrl}" />
                            </Border>

                            <!-- Name + place ID -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Profile.Name}" FontSize="13"
                                               FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <Border Background="#2D1B6E" CornerRadius="4" Padding="6,2"
                                            Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="Built-in" FontSize="9" Foreground="#A78BFA" />
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="Place" />
                                    <Run Text="{Binding Profile.PlaceId}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding FlagsSummary}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Toggle -->
                            <ui:ToggleSwitch Grid.Column="2" VerticalAlignment="Center"
                                             IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                             Click="ProfileToggle_Click" Tag="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Custom profiles ────────────────────────────────────────── -->
        <TextBlock FontSize="18" FontWeight="Medium" Margin="0,28,0,0"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}">
            <Run Text="✏️ Custom Profiles" />
        </TextBlock>
        <Border Height="2" Margin="0,6,0,12" CornerRadius="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#8B5CF6" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <WrapPanel Margin="0,0,0,12">
            <ui:Button Icon="Add28" Content="Add Profile" Appearance="Primary"
                       Click="AddProfile_Click" Margin="0,0,10,0" />
            <ui:Button Icon="ArrowImport24" Content="Import JSON"
                       Click="ImportProfile_Click" />
        </WrapPanel>

        <ItemsControl x:Name="UserList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="8" Padding="12,10" Margin="0,3" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Thumbnail -->
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="6"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Image Width="44" Height="44" Stretch="UniformToFill"
                                       Source="{Binding ThumbnailUrl}" />
                            </Border>

                            <!-- Name + place ID -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding Profile.Name}" FontSize="13"
                                           FontWeight="SemiBold" />
                                <TextBlock FontSize="11" Margin="0,2,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                    <Run Text="Place" />
                                    <Run Text="{Binding Profile.PlaceId}" />
                                    <Run Text=" · " />
                                    <Run Text="{Binding FlagsSummary}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Controls -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <ui:ToggleSwitch IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                                 Click="ProfileToggle_Click" Tag="{Binding}"
                                                 Margin="0,0,6,0" />
                                <ui:Button Icon="Edit24" Appearance="Secondary"
                                           Width="32" Height="32" Padding="0"
                                           Click="EditProfile_Click" Tag="{Binding}"
                                           Margin="0,0,4,0" />
                                <ui:Button Icon="Delete24" Appearance="Danger"
                                           Width="32" Height="32" Padding="0"
                                           Click="DeleteProfile_Click" Tag="{Binding}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock x:Name="NoCustomText" Text="No custom profiles yet — add one above."
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                   FontSize="13" Margin="0,8,0,0" Visibility="Collapsed" />

        <!-- ── Community ──────────────────────────────────────────────── -->
        <Border Margin="0,28,0,0" CornerRadius="8" Padding="16,12"
                BorderThickness="1" BorderBrush="#3D2D6B">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0f0720" Offset="0" />
                    <GradientStop Color="#1a0a2e" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#A78BFA">
                        <Run Text="🌐  Community Flag Presets" />
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="#8B7AB8" TextWrapping="Wrap"
                               Margin="0,4,0,0"
                               Text="Browse and import flag presets contributed by the community on GitHub." />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <ui:Button Content="Browse" Appearance="Secondary"
                               Click="BrowseCommunity_Click" Margin="0,0,8,0" />
                    <ui:Button Content="Share mine" Click="ShareFlags_Click" />
                </StackPanel>
            </Grid>
        </Border>

    </StackPanel>
</ui:UiPage>
